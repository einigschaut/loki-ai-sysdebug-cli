# === Secrets — NEVER commit (CLAUDE.md §5 / security scope) ===
*.env
.env
!config/.env.example

# === Large binaries & models — fetched via build/fetch-manifest.json, never in git ===
*.exe
*.gguf
*.gguf.part
*.part
*.dll
engine-offline/
bin/
tools/

# === Stick / build artifacts ===
build/out/
*.sig
manifest.sig

# === Test / temp output ===
testresults/
coverage.xml
*.tmp
*.log
docs/gen/*.tmp

# === Diagnostic dumps (`loki collect`) — NEVER commit ===
# A dump names the machine that produced it: computer name, IP addresses, DNS servers, adapter descriptions,
# running processes. Harmless on the stick it was written for, published data in a public repo. `loki collect`
# writes to <AppRoot>\reports\, so a run from a clone lands here and a careless `git add -A` ships someone's
# network topology. Ignored at the root and under src/ because AppRoot is src/ in a working copy (ADR-0018).
reports/
src/reports/

# === Claude Code local settings (per-machine, not shipped) ===
.claude/settings.local.json
